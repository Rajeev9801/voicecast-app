{
  "manifest_version": 3,
  "name": "VoiceCast - Microphone Access",
  "version": "1.0",
  "permissions": ["microphone"],
  "host_permissions": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["content.js"]
    }
  ]
}
